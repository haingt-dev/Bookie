    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\nconst slug = $('Determine Phase').item.json.book_slug;\nconst phase = $('Determine Phase').item.json.phase;\nconst progress = $('Determine Phase').item.json.progress;\n\nif (result.status === 'error') {\n  return [{ json: {\n    book_slug: slug,\n    status: '\\u274C Error',\n    phase: phase,\n    progress: progress,\n    error: (result.error || result.output || 'Unknown error').substring(0, 500),\n    notes: ''\n  } }];\n}\n\nreturn [{ json: {\n  book_slug: slug,\n  status: '\\u25B6 Start',\n  phase: phase,\n  progress: progress,\n  error: '',\n  notes: phase + ' completed'\n} }];"
      },
