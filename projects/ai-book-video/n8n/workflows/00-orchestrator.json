        880,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const slug = $('Find Actionable').first().json.book_slug;\nconst scanResult = $('Scan Books').first().json;\nconst books = scanResult.books || {};\nconst fileMap = books[slug] || {};\n\nconst pipeline = [\n  { phase: 'research',   artifact: 'notes.md',                type: 'llm' },\n  { phase: 'storyboard', artifact: 'storyboard.md',            type: 'llm' },\n  { phase: 'script',     artifact: 'chunks.md',                type: 'llm' },\n  { phase: 'voice',      artifact: 'audio/voiceover.wav',      type: 'production' },\n  { phase: 'visuals',    artifact: 'image-prompts.md',         type: 'production' },\n  { phase: 'render',     artifact: 'output/video.mp4',         type: 'production' },\n  { phase: 'post',       artifact: 'metadata.md',              type: 'llm' }\n];\n\nlet currentPhase = 'done';\nlet currentType = 'done';\nlet completedCount = 0;\n\nfor (const step of pipeline) {\n  if (fileMap[step.artifact] === true) {\n    completedCount++;\n  } else {\n    currentPhase = step.phase;\n    currentType = step.type;\n    break;\n  }\n}\n\nif (completedCount === pipeline.length) {\n  currentPhase = 'done';\n  currentType = 'done';\n}\n\nreturn [{ json: {\n  book_slug: slug,\n  phase: currentPhase,\n  phaseType: currentType,\n  progress: completedCount + '/' + pipeline.length,\n  completedCount,\n  totalPhases: pipeline.length\n} }];"
      },
