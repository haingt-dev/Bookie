      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst actionable = rows.filter(r => r.status === '\u25b6 Start');\n\nif (actionable.length === 0) {\n  return [];\n}\n\n// Process one book at a time to avoid race conditions\nreturn [{ json: actionable[0] }];"
      },
