    {
      "parameters": {
        "jsCode": "const phase = $('Determine Phase').item.json.phase;\nconst slug = $('Determine Phase').item.json.book_slug;\nconst progress = $('Determine Phase').item.json.progress;\n\nconst workflowMap = {\n  research:   { id: '02', name: 'Book Research' },\n  storyboard: { id: '03', name: 'Storyboard Creation' },\n  script:     { id: '04', name: 'Script Writing' },\n  post:       { id: '08', name: 'Post-production' }\n};\n\nconst wf = workflowMap[phase] || { id: '??', name: phase };\n\nreturn [{ json: {\n  book_slug: slug,\n  status: '\\u23F8 Manual \\u2014 run ' + wf.id + ' (' + wf.name + ')',\n  phase: phase,\n  progress: progress,\n  notes: 'Open workflow ' + wf.id + ' \\u2014 ' + wf.name + ' for ' + slug,\n  error: ''\n} }];"
      },
