# viXTTS TTS server
VIXTTS_API_URL=http://127.0.0.1:8020
VIXTTS_SPEAKER=fonos
VIXTTS_TEMPERATURE=0.85
VIXTTS_REPETITION_PENALTY=2.0

# viXTTS container management (optional — defaults in vixtts-server.sh)
# VIXTTS_API_PORT=8020
# VIXTTS_CONTAINER=vixtts-server
# VIXTTS_IMAGE=docker.io/daswer123/xtts-api-server:latest
# VIXTTS_DIR=~/.local/share/vixtts

# Gemini API (image generation)
GEMINI_API_KEY=your-api-key-here
GEMINI_IMAGE_SIZE=2K    # 512px | 1K | 2K | 4K (default: 2K)
